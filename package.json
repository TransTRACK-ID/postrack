{
  "name": "nuxt-app",
  "version": "0.9.4",
  "private": true,
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node --require dd-trace/init .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "db:generate:sqlite": "drizzle-kit generate --config drizzle.config.sqlite.ts",
    "db:migrate:sqlite": "drizzle-kit migrate --config drizzle.config.sqlite.ts",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:patch:push": "node scripts/bump-version.js patch --push",
    "version:minor:push": "node scripts/bump-version.js minor --push",
    "version:major:push": "node scripts/bump-version.js major --push",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "build:electron": "tsup electron/main.ts electron/preload.ts --out-dir electron-dist --platform node --format esm --external electron --external electron-updater",
    "electron:dev": "pnpm build:electron && env -u ELECTRON_RUN_AS_NODE electron electron-dist/main.js",
    "electron:build": "pnpm build:electron && NUXT_DESKTOP_BUILD=true nuxt build && env -u ELECTRON_RUN_AS_NODE electron-builder",
    "electron:build:win": "pnpm build:electron && NUXT_DESKTOP_BUILD=true nuxt build && env -u ELECTRON_RUN_AS_NODE electron-builder --win",
    "electron:build:mac": "pnpm build:electron && NUXT_DESKTOP_BUILD=true nuxt build && env -u ELECTRON_RUN_AS_NODE electron-builder --mac",
    "electron:build:linux": "pnpm build:electron && NUXT_DESKTOP_BUILD=true nuxt build && env -u ELECTRON_RUN_AS_NODE electron-builder --linux",
    "postinstall:electron": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@datadog/browser-logs": "^5.35.1",
    "@datadog/browser-rum": "^5.35.1",
    "@faker-js/faker": "^9.2.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@vercel/kv": "^1.0.1",
    "better-sqlite3": "^11.5.0",
    "dd-trace": "^4.55.0",
    "drizzle-orm": "^0.38.3",
    "electron-updater": "^6.3.0",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.1",
    "nuxt": "^3.20.2",
    "perfect-debounce": "^2.0.0",
    "pg": "^8.18.0",
    "uuid": "^13.0.0",
    "vue": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.30.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.0",
    "jsdom": "^26.0.0",
    "@vue/test-utils": "^2.4.0"
  }
}
