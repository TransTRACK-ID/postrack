{
  "name": "nuxt-app",
  "version": "0.9.11",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node --require dd-trace/init .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:patch:push": "node scripts/bump-version.js patch --push",
    "version:minor:push": "node scripts/bump-version.js minor --push",
    "version:major:push": "node scripts/bump-version.js major --push",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k \"pnpm dev\" \"wait-on http://localhost:3000 && pnpm electron:compile && electron .\"",
    "electron:start": "pnpm electron:compile && electron .",
    "electron:build:app": "cross-env BUILD_TARGET=electron pnpm build && pnpm electron:compile",
    "electron:dist": "pnpm electron:build:app && electron-builder --mac --arm64",
    "electron:dist:dir": "pnpm electron:build:app && electron-builder --mac --arm64 --dir",
    "test:electron": "vitest run tests/electron",
    "test:e2e:electron": "playwright test tests/e2e/electron"
  },
  "dependencies": {
    "@datadog/browser-logs": "^5.35.1",
    "@datadog/browser-rum": "^5.35.1",
    "@faker-js/faker": "^9.2.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@vercel/kv": "^1.0.1",
    "dd-trace": "^4.55.0",
    "drizzle-orm": "^0.38.3",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "marked": "^17.0.1",
    "nuxt": "^3.20.2",
    "perfect-debounce": "^2.0.0",
    "pg": "^8.18.0",
    "uuid": "^13.0.0",
    "vue": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@vue/test-utils": "^2.4.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.3"
  }
}
